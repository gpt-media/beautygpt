{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/my/ms/:path*", "destination": "/ms/:path*", "permanent": true },
    { "source": "/my/zh/:path*", "destination": "/zh/:path*", "permanent": true },
    { "source": "/my/:path*", "destination": "/:path*", "permanent": true },
    { "source": "/my", "destination": "/", "permanent": true }
  ]
}
