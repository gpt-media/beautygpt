---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="TheBeautyGPT"
  description="Evidence-led skincare answers, built for your market and language. Choose your region."
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Skincare, decoded</p>
      <h1 class="tagline">Smarter answers for your skin.</h1>
      <p>Evidence-led skincare guidance, in your language. Choose your region:</p>
      <ul class="region-list">
        <li>
          <a href="/my/">Malaysia</a>
          <div class="langs"><a href="/my/">English</a> · <a href="/my/ms/">BM</a> · <a href="/my/zh/">中文</a></div>
        </li>
        <li>
          <a href="/sg/">Singapore</a>
          <div class="langs"><a href="/sg/">English</a> · BM &amp; 中文 coming soon</div>
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
