---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from '../components/Newsletter.astro';

// Root homepage (/). This is the primary, x-default home: the GLOBAL English edition. It features
// the global articles (rendered at /articles/<slug>/). The regional editions (/my/, /sg/ ...) and
// their hubs are untouched; this page lists only the global collection. Data-driven: it grows
// automatically as PASS 2 fans out more global articles.
const all = (await getCollection('articles-global')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });

// Featured pillars surface first; everything else lists under "Latest". Kept simple and
// data-driven so no slug list needs maintaining as the global edition grows (cluster
// partitioning can be reintroduced once the global spoke set lands in PASS 2).
const pillars = all.filter((a) => a.data.featured);
const rest = all.filter((a) => !a.data.featured);

const sections = [
  { title: 'Start here', items: pillars },
  { title: 'Latest', items: rest },
];
---
<BaseLayout
  title="TheBeautyGPT"
  description="Evidence-led answers to your skincare questions: acne, patches, dark spots, and what actually works. Clear comparisons and real mechanisms."
  path="/"
  neutral
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Skincare, decoded</p>
      <h1 class="tagline">Smarter answers for your skin.</h1>
      <p>Evidence-led skincare guidance: acne, patches, dark spots, and what actually works. Clear comparisons, real mechanisms, and honest recommendations.</p>
    </div>
  </section>

  <div class="wrap">
    <section class="cluster">
      <h2 class="section-title">Topic hubs</h2>
      <ul class="article-list">
        <li>
          <a class="title" href="/articles/best-acne-patches-2026/">Acne Patches: the complete guide</a>
          <p>Which patch type works for which pimple, the best patch by skin type, how to use them, and where to buy. The canonical home for everything on acne patches.</p>
          <span class="meta">Topic hub</span>
        </li>
      </ul>
    </section>
    {sections.map((section) => section.items.length > 0 && (
      <section class="cluster">
        <h2 class="section-title">{section.title}</h2>
        <ul class="article-list">
          {section.items.map((a) => (
            <li>
              <a class="title" href={`/articles/${a.slug}/`}>{a.data.title}</a>
              <p>{a.data.description}</p>
              <span class="meta">{a.data.category} · {fmt(a.data.publishDate)}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}
    {all.length === 0 && <p>First answers publishing soon.</p>}
    <Newsletter lang="en" market="my" global />
  </div>
</BaseLayout>
