---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleView from '../../components/ArticleView.astro';
import { SITE_NAME, SITE_URL, AUTHOR } from '../../lib/site';

// Original-data reports — the GPT-original-data studies. Rendered at /reports/<slug>/ reusing the
// shared article body (BaseLayout + ArticleView), so a report looks like a normal article page.
// A report ships its OWN bespoke Dataset + Article JSON-LD (figures + citations are specific to the
// study) instead of the auto-built article schema, so this template constructs jsonLd inline.
export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const fmt = (dt: Date) => dt.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
const path = `/reports/${entry.slug}/`;
const url = new URL(path, Astro.site).href;

// Canonical citations for this report (DOIs of the primary + peer-reviewed sources).
const citations = [
  'https://doi.org/10.1111/bjd.20882',
  'https://doi.org/10.1038/jid.2013.446',
  'https://doi.org/10.1111/bjd.13462',
  'https://doi.org/10.3389/fmed.2022.939584',
];

// Bespoke structured data: a Dataset (the original-data map) + an Article (the page), both
// pointing at the canonical /reports/<slug>/ URL. Emitted as two top-level <script ld+json>
// blocks by BaseLayout (equivalent to the source @graph; never a visible code block).
const datasetLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: d.title,
  description:
    'Compilation of global acne vulgaris prevalence, peak age, sex differences, and geographic distribution, sourced from the Global Burden of Disease Study (GBD 2010 and GBD 2019) and peer-reviewed dermatology epidemiology.',
  url,
  datePublished: d.publishDate.toISOString().slice(0, 10),
  creator: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
  license: 'https://creativecommons.org/licenses/by/4.0/',
  keywords: ['acne vulgaris', 'prevalence', 'Global Burden of Disease', 'epidemiology', 'skin disease', 'dermatology'],
  temporalCoverage: '2010/2019',
  variableMeasured: [
    { '@type': 'PropertyValue', name: 'Global prevalence of acne vulgaris', value: '9.4', unitText: 'PERCENT', description: 'Share of global population affected (GBD 2010, via Tan and Bhate 2015)' },
    { '@type': 'PropertyValue', name: 'Global prevalent cases', value: '231200000', unitText: 'people', description: 'GBD 2019, 95% UI 208.2 to 255.5 million' },
    { '@type': 'PropertyValue', name: 'Global incident cases', value: '117400000', unitText: 'people per year', description: 'GBD 2019' },
    { '@type': 'PropertyValue', name: 'Peak prevalence age band', value: '15-19 years' },
    { '@type': 'PropertyValue', name: 'Peak incidence age band', value: '10-14 years' },
    { '@type': 'PropertyValue', name: 'Female to male age-standardised rate ratio', value: '1.3', description: 'GBD 2019' },
  ],
  citation: citations,
};

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  additionalType: 'https://schema.org/MedicalWebPage',
  headline: d.title,
  description:
    'Acne vulgaris affects an estimated 9.4 percent of the global population, the eighth most prevalent disease worldwide, with roughly 231 million prevalent cases counted in the Global Burden of Disease Study 2019.',
  datePublished: d.publishDate.toISOString().slice(0, 10),
  author: { '@type': 'Organization', name: AUTHOR.name, url: AUTHOR.url },
  publisher: { '@type': 'Organization', name: SITE_NAME, url: SITE_URL },
  mainEntityOfPage: url,
  citation: citations,
};

const jsonLd = [datasetLd, articleLd];
---
<BaseLayout title={d.title} description={d.description} jsonLd={jsonLd} ogType="article" lang="en" global image={d.image} path={path}>
  <ArticleView
    data={d}
    lang="en"
    global
    Content={Content}
    fmt={fmt}
    labels={{ by: 'By', published: 'Published', updated: 'Updated', faqHeading: 'Frequently asked questions' }}
  />
</BaseLayout>
