---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ArticleView from '../../../../components/ArticleView.astro';
import { buildArticleJsonLd } from '../../../../lib/article-schema';

export async function getStaticPaths() {
  const articles = await getCollection('articles-sg-zh');
  return articles.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const fmt = (dt: Date) => dt.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
const abs = (p: string) => new URL(p, Astro.site).href;
const url = abs(`/sg/zh/articles/${entry.slug}/`);

const jsonLd = buildArticleJsonLd({ data: d, inLanguage: 'zh-SG', url, abs });
---
<BaseLayout title={d.title} description={d.description} jsonLd={jsonLd} ogType="article" lang="zh" market="sg" image={d.image} path={`/articles/${entry.slug}/`}>
  <ArticleView
    data={d}
    lang="zh"
    market="sg"
    Content={Content}
    fmt={fmt}
    labels={{ by: '作者', published: '发布于', updated: '更新于', faqHeading: '常见问题' }}
  />
</BaseLayout>
