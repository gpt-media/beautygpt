---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleView from '../../../components/ArticleView.astro';
import { buildArticleJsonLd } from '../../../lib/article-schema';

export async function getStaticPaths() {
  const articles = await getCollection('articles-sg');
  return articles.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const fmt = (dt: Date) => dt.toLocaleDateString('en-SG', { year: 'numeric', month: 'long', day: 'numeric' });
const abs = (p: string) => new URL(p, Astro.site).href;
const url = abs(`/sg/articles/${entry.slug}/`);

const jsonLd = buildArticleJsonLd({ data: d, inLanguage: 'en-SG', url, abs, body: entry.body });
---
<BaseLayout title={d.title} description={d.description} jsonLd={jsonLd} ogType="article" lang="en" market="sg" image={d.image} path={`/articles/${entry.slug}/`}>
  <ArticleView
    data={d}
    lang="en"
    market="sg"
    Content={Content}
    fmt={fmt}
    labels={{ by: 'By', published: 'Published', updated: 'Updated', faqHeading: 'Frequently asked questions' }}
  />
</BaseLayout>
