---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en-MY', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout
  title="TheBeautyGPT"
  description="Evidence-led answers to your skincare questions, built for Malaysian skin. Clear comparisons, real mechanisms, and what actually works."
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Skincare, decoded</p>
      <h1 class="tagline">Smarter answers for your skin.</h1>
      <p>Evidence-led skincare guidance for Malaysian skin — acne, patches, dark spots, and what actually works. Clear comparisons, real mechanisms, prices in ringgit.</p>
    </div>
  </section>

  <div class="wrap">
    <ul class="article-list">
      {articles.map((a) => (
        <li>
          <a class="title" href={`/my/articles/${a.slug}/`}>{a.data.title}</a>
          <p>{a.data.description}</p>
          <span class="meta">{a.data.category} · {fmt(a.data.publishDate)}</span>
        </li>
      ))}
      {articles.length === 0 && <li><p>First answers publishing soon.</p></li>}
    </ul>
  </div>
</BaseLayout>
