---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_NAME, SITE_URL, AUTHOR, FOUNDING_DATE, KNOWS_ABOUT, PUBLISHING_PRINCIPLES } from '../../lib/site';

const abs = (p: string) => new URL(p, Astro.site).href;
const aboutLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: `About ${SITE_NAME}`,
    url: abs('/zh/about/'),
    mainEntity: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
      description: 'Evidence-led skincare guidance: acne, patches, ingredients, and what actually works.',
      foundingDate: FOUNDING_DATE,
      knowsAbout: KNOWS_ABOUT,
      publishingPrinciples: PUBLISHING_PRINCIPLES,
    },
  },
];
---
<BaseLayout
  lang="zh"
  path="/about/"
  neutral
  jsonLd={aboutLd}
  title="关于我们"
  description="TheBeautyGPT 提供以证据为本的护肤解答：清晰的比较、真实的作用原理，以及立足于成分和疗法真正如何起作用的建议。"
>
  <article class="article">
    <div class="wrap">
      <p class="kicker">关于我们</p>
      <h1>护肤知识，清楚解读。</h1>
      <div class="article-body">
        <p>TheBeautyGPT 把一个问题答好：<em>什么才真正适合我的肌肤？</em>网上找到的资讯大多含糊不清，或者难以付诸行动。我们提供清晰、以证据为本的解答，立足于肌肤与成分真正如何运作。</p>

        <h2>我们的做法</h2>
        <ul>
          <li><strong>原理优先。</strong>在谈到产品之前，我们先解释一样东西<em>为什么</em>有效（或无效）：水胶体 (hydrocolloid) 对比微针 (microneedle)、活性成分、配方。</li>
          <li><strong>真实比较。</strong>我们把值得考虑的真实选项逐一并排权衡。</li>
          <li><strong>实用指引。</strong>一款产品相对同类的价格、什么时候更便宜的选择也能做到同样的事，以及什么适合你的肌肤和气候。</li>
        </ul>

        <h2>谁来撰写与审核</h2>
        <p>我们的文章由 <strong>{AUTHOR.name}</strong> 研究并撰写，这是一支以研究为本的团队，会阅读皮肤科资料（例如美国皮肤病学会 American Academy of Dermatology、DermNet 和英国 NHS 的临床指南），并把它翻译成通俗易懂的语言。我们会为证据的强弱评级（充分、参差或初步），而不是把一切都说成已成定论。</p>
        <p>每篇文章都依据我们的<a href="/zh/editorial-standards/">编辑标准</a>审核：解释原理、诚实评级证据、准确描述成分，绝不把结论夸大到研究支持之外。当诚实的答案是“证据不足”或“你并不需要它”时，我们就照实说。我们不会以虚构的署名发表。</p>
        <p>关于我们如何研究、为证据分级并审核每篇文章，以及一段关于医疗审核的坦诚说明，请见<a href="/zh/how-we-review/">我们如何评测</a>。</p>

        <h2>非医疗建议</h2>
        <p>我们的内容仅供教育参考。如果肌肤问题持续、疼痛或严重，请咨询医生或注册皮肤科医生。</p>
      </div>
    </div>
  </article>
</BaseLayout>
