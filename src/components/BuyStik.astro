---
// BuyStik.astro: a neutral "where to find it" note for readers who have decided on a STIK patch.
//
// This is an independent-presenting review site, so this block reads like a normal review-site
// "where to buy" note, NOT a loud CTA. Factual, in-language, no hype. Links carry
// rel="nofollow noopener" target="_blank" and NO UTM params (UTM would signal ownership).
//
// Single source of truth for the links is STIK_BUY in lib/site.ts.
// Market-aware: renders only the NON-EMPTY channels for the given market (Shopee / TikTok Shop /
// official store), and renders NOTHING if that market has no channels yet. So the SG path stays
// dormant until STIK_BUY.sg is populated — no code change needed to light it up.
import { STIK_BUY } from '../lib/site';

interface Props {
  lang?: 'en' | 'ms' | 'zh';
  market?: 'my' | 'sg';
}
const { lang = 'en', market = 'my' } = Astro.props;

const MARKET_NAME = {
  my: { en: 'Malaysia', ms: 'Malaysia', zh: '马来西亚' },
  sg: { en: 'Singapore', ms: 'Singapura', zh: '新加坡' },
} as const;
const m = MARKET_NAME[market][lang];

const LABELS = {
  en: { shopee: 'Shopee', tiktokShop: 'TikTok Shop', officialStore: 'Official store' },
  ms: { shopee: 'Shopee', tiktokShop: 'TikTok Shop', officialStore: 'Kedai rasmi' },
  zh: { shopee: 'Shopee', tiktokShop: 'TikTok Shop', officialStore: '官方商店' },
} as const;
const lab = LABELS[lang];

// Market-named heading + intro (in-language).
const HEAD = {
  en: { heading: `Where to buy STIK in ${m}`, intro: `STIK patches are sold on these official channels in ${m}:` },
  ms: { heading: `Di mana untuk membeli STIK di ${m}`, intro: `Patch STIK dijual di saluran rasmi ini di ${m}:` },
  zh: { heading: `在${m}哪里购买 STIK`, intro: `STIK 痘痘贴在${m}通过以下官方渠道销售：` },
} as const;
const c = HEAD[lang];

// Build from the market's channels; drop any empty (unconfigured) channel.
const ch = STIK_BUY[market];
const links = [
  { label: lab.shopee, href: ch.shopee },
  { label: lab.tiktokShop, href: ch.tiktokShop },
  { label: lab.officialStore, href: ch.officialStore },
].filter((l) => l.href);
---
{links.length > 0 && (
  <aside class="buy-stik" aria-label={c.heading}>
    <p class="bs-label">{c.heading}</p>
    <p class="bs-intro">{c.intro}</p>
    <ul class="bs-links">
      {links.map((l) => (
        <li>
          <a href={l.href} rel="nofollow noopener" target="_blank">{l.label}</a>
        </li>
      ))}
    </ul>
  </aside>
)}
