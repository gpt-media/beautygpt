---
// Newsletter.astro: first-party audience capture for the media -> commerce funnel.
//
// Renders ONLY when NEWSLETTER.enabled is true (founder flips it once an ESP/endpoint is chosen
// (PII handling + the independent-publication footprint are a founder call). Until then it ships
// dormant: no dead form on the live site. In-language; links to the edition's privacy page.
import { NEWSLETTER } from '../lib/site';
import { UI } from '../lib/i18n';
import type { Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
  market?: 'my' | 'sg';
  /** Global/market-less edition: link the neutral privacy page (/privacy/, /ms/privacy/ ...)
   *  rather than a market-scoped one. */
  global?: boolean;
}
const { lang = 'en', market = 'my', global = false } = Astro.props;
const t = UI[lang];
const nl = NEWSLETTER;
// Privacy link: neutral edition (/privacy/) when global, else the market+language edition.
const privacyHref = global
  ? `/${lang === 'en' ? '' : lang + '/'}privacy/`
  : `/${market}${lang === 'en' ? '' : '/' + lang}/privacy/`;
---
{nl.enabled && (
  <aside class="newsletter" aria-label={t.nlHeading}>
    <div class="nl-inner">
      <h2 class="nl-heading">{t.nlHeading}</h2>
      <p class="nl-sub">{t.nlSub}</p>
      <form class="nl-form" action={nl.action} method="post">
        <input
          class="nl-input"
          type="email"
          name="email"
          required
          autocomplete="email"
          placeholder={t.nlPlaceholder}
          aria-label={t.nlPlaceholder}
        />
        <button class="nl-button" type="submit">{t.nlButton}</button>
      </form>
      <p class="nl-privacy"><a href={privacyHref}>{t.nlPrivacy}</a></p>
    </div>
  </aside>
)}
