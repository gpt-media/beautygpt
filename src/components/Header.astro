---
// Markets live under /my/ and /sg/; the bare root is a region landing.
// Detect market + language so logo, nav, and switcher point to the right place.
const p = Astro.url.pathname;
const isMY = p === '/my' || p.startsWith('/my/');
const isSG = p === '/sg' || p.startsWith('/sg/');
const market = isMY ? 'my' : isSG ? 'sg' : null;

let lang: 'en' | 'ms' | 'zh' = 'en';
let home = '/';
let about = '/';
if (market) {
  const mB = `/${market}`;
  let rest = p.slice(3) || '/';
  if (rest === '/ms' || rest.startsWith('/ms/')) { lang = 'ms'; rest = rest.slice(3) || '/'; }
  else if (rest === '/zh' || rest.startsWith('/zh/')) { lang = 'zh'; rest = rest.slice(3) || '/'; }
  const lB = lang === 'en' ? '' : `/${lang}`;
  home = `${mB}${lB}/`;
  about = `${mB}${lB}/about/`;
}
const t = {
  home: { en: 'Home', ms: 'Laman Utama', zh: '首页' }[lang],
  about: { en: 'About', ms: 'Tentang', zh: '关于' }[lang],
};
---
<header class="site-header">
  <div class="wrap">
    <a href={market ? home : '/'} class="logo">The<span>Beauty</span>GPT</a>
    {market && (
      <nav>
        <a href={home}>{t.home}</a>
        <a href={about}>{t.about}</a>
      </nav>
    )}
  </div>
</header>
