---
// Market (Malaysia at root, Singapore at /sg/) + language detection, so the logo,
// nav, and language switcher point to the right place for the page you're on.
const p = Astro.url.pathname;
const isSG = p === '/sg' || p.startsWith('/sg/');
let rest = isSG ? (p.slice(3) || '/') : p;
let lang: 'en' | 'ms' | 'zh' = 'en';
if (rest === '/ms' || rest.startsWith('/ms/')) { lang = 'ms'; rest = rest.slice(3) || '/'; }
else if (rest === '/zh' || rest.startsWith('/zh/')) { lang = 'zh'; rest = rest.slice(3) || '/'; }

const mB = isSG ? '/sg' : '';
const lB = (l: string) => (l === 'en' ? '' : '/' + l);
const home = `${mB}${lB(lang)}/`;
const about = `${mB}${lB(lang)}/about/`;
const t = {
  home: { en: 'Home', ms: 'Laman Utama', zh: '首页' }[lang],
  about: { en: 'About', ms: 'Tentang', zh: '关于' }[lang],
};
const sw = { en: `${mB}${rest}`, ms: `${mB}/ms${rest}`, zh: `${mB}/zh${rest}` };
---
<header class="site-header">
  <div class="wrap">
    <a href={home} class="logo">The<span>Beauty</span>GPT</a>
    <nav>
      <a href={home}>{t.home}</a>
      <a href={about}>{t.about}</a>
      <span class="lang-switch">
        <a href={sw.en} class={lang === 'en' ? 'on' : ''}>EN</a>
        <a href={sw.ms} class={lang === 'ms' ? 'on' : ''}>BM</a>
        <a href={sw.zh} class={lang === 'zh' ? 'on' : ''}>中文</a>
      </span>
    </nav>
  </div>
</header>
