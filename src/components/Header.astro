---
// Detect current language + the language-agnostic path suffix, so the logo, nav,
// and language switcher all point to the right place for the page you're on.
// Home market (Malaysia) lives at the root: '/', '/ms/', '/zh/'.
const p = Astro.url.pathname;
let lang: 'en' | 'ms' | 'zh' = 'en';
let suffix = '/';
if (p === '/ms' || p.startsWith('/ms/')) { lang = 'ms'; suffix = p.slice(3) || '/'; }
else if (p === '/zh' || p.startsWith('/zh/')) { lang = 'zh'; suffix = p.slice(3) || '/'; }
else { lang = 'en'; suffix = p || '/'; }

const home = { en: '/', ms: '/ms/', zh: '/zh/' }[lang];
const about = { en: '/about/', ms: '/ms/about/', zh: '/zh/about/' }[lang];
const t = {
  home: { en: 'Home', ms: 'Laman Utama', zh: '首页' }[lang],
  about: { en: 'About', ms: 'Tentang', zh: '关于' }[lang],
};
const sw = { en: `${suffix}`, ms: `/ms${suffix}`, zh: `/zh${suffix}` };
---
<header class="site-header">
  <div class="wrap">
    <a href={home} class="logo">The<span>Beauty</span>GPT</a>
    <nav>
      <a href={home}>{t.home}</a>
      <a href={about}>{t.about}</a>
      <span class="lang-switch">
        <a href={sw.en} class={lang === 'en' ? 'on' : ''}>EN</a>
        <a href={sw.ms} class={lang === 'ms' ? 'on' : ''}>BM</a>
        <a href={sw.zh} class={lang === 'zh' ? 'on' : ''}>中文</a>
      </span>
    </nav>
  </div>
</header>
