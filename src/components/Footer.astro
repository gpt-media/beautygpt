---
const year = 2026;
const p = Astro.url.pathname;
const isMY = p === '/my' || p.startsWith('/my/');
const isSG = p === '/sg' || p.startsWith('/sg/');
const market = isMY ? 'my' : isSG ? 'sg' : null;

// Region/language switch lives in the footer now (clean, authority-style header).
// Compute the same-page link in each language. No auto-redirect; the reader chooses.
let lang: 'en' | 'ms' | 'zh' = 'en';
let base = '';
let sw = { en: '/', ms: '/', zh: '/' };
if (market) {
  const mB = `/${market}`;
  let rest = p.slice(3) || '/';
  if (rest === '/ms' || rest.startsWith('/ms/')) { lang = 'ms'; rest = rest.slice(3) || '/'; }
  else if (rest === '/zh' || rest.startsWith('/zh/')) { lang = 'zh'; rest = rest.slice(3) || '/'; }
  base = `${mB}${lang === 'en' ? '' : '/' + lang}`;
  sw = { en: `${mB}${rest}`, ms: `${mB}/ms${rest}`, zh: `${mB}/zh${rest}` };
}
const t = {
  about: { en: 'About', ms: 'Tentang', zh: '关于' }[lang],
  standards: { en: 'Editorial Standards', ms: 'Piawaian Editorial', zh: '编辑标准' }[lang],
  disclaimer: { en: 'Medical Disclaimer', ms: 'Penafian Perubatan', zh: '医疗免责声明' }[lang],
};
---
<footer class="site-footer">
  <div class="wrap">
    {market && (
      <nav class="footer-nav">
        <a href={`${base}/about/`}>{t.about}</a>
        <a href={`${base}/editorial-standards/`}>{t.standards}</a>
        <a href={`${base}/medical-disclaimer/`}>{t.disclaimer}</a>
      </nav>
    )}
    {market && (
      <span class="lang-switch footer-langs">
        <a href={sw.en} class={lang === 'en' ? 'on' : ''}>EN</a>
        <a href={sw.ms} class={lang === 'ms' ? 'on' : ''}>BM</a>
        <a href={sw.zh} class={lang === 'zh' ? 'on' : ''}>中文</a>
      </span>
    )}
    <p class="fineprint">&copy; {year} TheBeautyGPT. All rights reserved.</p>
  </div>
</footer>
