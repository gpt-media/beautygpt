---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, SITE_URL, OG_IMAGE, FOUNDING_DATE, KNOWS_ABOUT, PUBLISHING_PRINCIPLES, CF_BEACON_TOKEN } from '../lib/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Structured data objects (schema.org) injected as JSON-LD - the AIO backbone. */
  jsonLd?: Record<string, any>[];
  ogType?: string;
  /** Content language. Drives <html lang> + og:locale. 'en' | 'ms' (Malay) | 'zh' (Chinese). */
  lang?: 'en' | 'ms' | 'zh';
  /** Market region. 'my' (Malaysia) | 'sg' (Singapore). Sets the region in <html lang> + og:locale. */
  market?: 'my' | 'sg';
  /** Language-agnostic path suffix (e.g. '/', '/about/', '/articles/foo/') used to build hreflang alternates. */
  path?: string;
  /** Country-neutral page (homepage + general/governance pages). When true, hreflang alternates
   *  and the breadcrumb Home crumb use language-only URLs (en at /, ms at /ms/, zh at /zh/) with
   *  no market segment, and the lang/locale codes drop the region suffix. Articles + the /sg/,
   *  /my/ms/ ... edition homepages leave this false and keep their market-scoped behavior. */
  neutral?: boolean;
  /** per-page OG/social image (absolute path under the domain); falls back to OG_IMAGE. */
  image?: string;
  /** Optional explicit breadcrumb trail (name + path under the edition root, excluding Home).
   *  When provided, overrides the auto-derived 2-level (Home > page) trail. Used to give
   *  cluster articles a 3-level trail (Home > Acne Patches > article). */
  breadcrumbs?: { name: string; path: string }[];
}

const { title, description, jsonLd = [], ogType = 'website', lang = 'en', market = 'my', path, image, breadcrumbs, neutral = false } = Astro.props;
const reg = market === 'sg' ? 'SG' : 'MY';
// Neutral (country-agnostic) pages use language-only codes; market pages keep the region suffix.
const langCode = neutral ? { en: 'en', ms: 'ms', zh: 'zh' }[lang] : `${ { en: 'en', ms: 'ms', zh: 'zh' }[lang] }-${reg}`;
const ogLocale = neutral ? { en: 'en', ms: 'ms', zh: 'zh' }[lang] : `${ { en: 'en', ms: 'ms', zh: 'zh' }[lang] }_${reg}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ?? OG_IMAGE;
const ogImageAbs = ogImage ? new URL(ogImage, Astro.site).href : '';
// hreflang alternates (only when the page exists in all three languages; pass `path`).
// Neutral pages: en at /, ms at /ms/, zh at /zh/ (no market segment), x-default -> English root.
// Market pages: /my|/sg root with /ms, /zh language sub-paths, x-default -> the en market root.
const hb = market === 'sg' ? '/sg' : '/my';
const alternates = path
  ? neutral
    ? [
        { hreflang: 'en', href: new URL(`${path}`, Astro.site).href },
        { hreflang: 'ms', href: new URL(`/ms${path}`, Astro.site).href },
        { hreflang: 'zh', href: new URL(`/zh${path}`, Astro.site).href },
        { hreflang: 'x-default', href: new URL(`${path}`, Astro.site).href },
      ]
    : [
        { hreflang: `en-${reg}`, href: new URL(`${hb}${path}`, Astro.site).href },
        { hreflang: `ms-${reg}`, href: new URL(`${hb}/ms${path}`, Astro.site).href },
        { hreflang: `zh-${reg}`, href: new URL(`${hb}/zh${path}`, Astro.site).href },
        { hreflang: 'x-default', href: new URL(`${hb}${path}`, Astro.site).href },
      ]
  : [];
const fullTitle = title === 'TheBeautyGPT'
  ? 'TheBeautyGPT: Smarter answers for your skin'
  : `${title} | TheBeautyGPT`;

// BreadcrumbList, derived from the URL so every non-home page gets a valid trail
// (Home > current page) with no per-page wiring. Home crumb points at the edition
// root for the page's market+language; publisher entity stays TheBeautyGPT.
const editionRoot = (neutral ? '' : hb) + (lang === 'en' ? '' : '/' + lang) + '/';
// Explicit trail (e.g. Home > Acne Patches > article) when `breadcrumbs` is passed;
// otherwise the auto-derived Home > current-page trail.
const crumbItems = breadcrumbs
  ? [
      { '@type': 'ListItem', position: 1, name: 'TheBeautyGPT', item: new URL(editionRoot, Astro.site).href },
      ...breadcrumbs.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 2,
        name: c.name,
        item: new URL(c.path, Astro.site).href,
      })),
    ]
  : [
      { '@type': 'ListItem', position: 1, name: 'TheBeautyGPT', item: new URL(editionRoot, Astro.site).href },
      { '@type': 'ListItem', position: 2, name: title, item: canonical },
    ];
const breadcrumbLd = Astro.url.pathname === editionRoot
  ? null
  : {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: crumbItems,
    };
---
<!doctype html>
<html lang={langCode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Open Graph / social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="TheBeautyGPT" />
    <meta property="og:locale" content={ogLocale} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}

    <!-- Organization structured data - establishes the publisher entity for AI engines -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
      description: 'Evidence-led skincare guidance: acne, patches, ingredients, and what actually works.',
      foundingDate: FOUNDING_DATE,
      knowsAbout: KNOWS_ABOUT,
      publishingPrinciples: PUBLISHING_PRINCIPLES,
      logo: `${SITE_URL}/favicon.svg`,
    })} />

    <!-- WebSite structured data - site-level entity for search + AI engines -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'TheBeautyGPT',
      url: 'https://thebeautygpt.com',
      inLanguage: langCode,
      publisher: { '@type': 'Organization', name: 'TheBeautyGPT', url: 'https://thebeautygpt.com' },
    })} />

    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon (SVG: crisp at any size; supported by current browsers + Google SERP) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" sizes="any" />
    <meta name="theme-color" content="#c8503c" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    {CF_BEACON_TOKEN && <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={JSON.stringify({ token: CF_BEACON_TOKEN })}></script>}
  </body>
</html>
